{
    "name": "openrct2-colors-manager",
    "version": "1.0.0",
    "description": "OpenRCT2 plugin that auto-recolors stall items (balloons, umbrellas, hats, t-shirts).",
    "type": "module",
    "scripts": {
        "build": "node build.mjs",
        "build:dev": "node build.mjs --dev",
        "watch": "node build.mjs --watch",
        "watch:dev": "node build.mjs --dev --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:cov": "vitest run --coverage"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CarterPape/openrct2-colors-manager.git"
    },
    "author": "Carter Pape",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/CarterPape/openrct2-colors-manager/issues"
    },
    "homepage": "https://github.com/CarterPape/openrct2-colors-manager#readme",
    "devDependencies": {
        "@vitest/coverage-v8": "^3",
        "esbuild": "^0.25",
        "openrct2-mocks": "^0.1",
        "typescript": "^5.7",
        "vitest": "^3"
    },
    "engines": {
        "node": ">=20"
    }
}
